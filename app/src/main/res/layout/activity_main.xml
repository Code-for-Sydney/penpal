<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- Full-screen Drawing Canvas -->
    <com.drawapp.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/recognitionPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── AI Recognition Result Panel ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/recognitionPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#CC0A0A1A"
        app:layout_constraintBottom_toTopOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Spinning indicator (visible while inferring) -->
        <ProgressBar
            android:id="@+id/recognitionProgress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="#7C4DFF"
            android:visibility="gone"
            android:layout_marginEnd="10dp" />

        <!-- AI sparkle icon (visible when idle/done) -->
        <TextView
            android:id="@+id/recognitionIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textColor="#7C4DFF"
            android:textSize="16sp"
            android:layout_marginEnd="10dp" />

        <!-- Hint / recognized text -->
        <TextView
            android:id="@+id/recognitionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Draw something to recognize…"
            android:textColor="#88FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Bottom Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/toolbar_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Color swatch / picker trigger -->
        <View
            android:id="@+id/colorSwatch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/color_swatch_bg"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- Brush Size -->
        <ImageButton
            android:id="@+id/btnBrushSize"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_brush"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Brush size"
            android:tint="#CCCCCC"
            android:layout_marginStart="4dp" />

        <!-- Eraser -->
        <ImageButton
            android:id="@+id/btnEraser"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_eraser"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Eraser"
            android:tint="#CCCCCC"
            android:layout_marginStart="8dp" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Undo -->
        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_undo"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Undo"
            android:tint="#CCCCCC"
            android:alpha="0.4"
            android:layout_marginEnd="8dp" />

        <!-- Redo -->
        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_redo"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Redo"
            android:tint="#CCCCCC"
            android:alpha="0.4"
            android:layout_marginEnd="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#33FFFFFF"
            android:layout_marginEnd="8dp" />

        <!-- Clear -->
        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_delete"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Clear canvas"
            android:tint="#FF6B6B"
            android:layout_marginEnd="8dp" />

        <!-- Save -->
        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_save"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Save"
            android:tint="#64FFDA" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
