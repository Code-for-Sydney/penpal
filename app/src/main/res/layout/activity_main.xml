<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- Full-screen Drawing Canvas -->
    <com.drawapp.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/recognitionPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Bar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:tint="#000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNotebookTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="64dp"
        android:text="Notebook"
        android:textColor="#40FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnJumpMarkers"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_star"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Jump to markers"
        android:tint="#CCCCCC"
        app:layout_constraintEnd_toStartOf="@id/btnSearch"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnSearch"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_search"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Search"
        android:tint="#CCCCCC"
        app:layout_constraintEnd_toStartOf="@id/btnOverview"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnOverview"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_grid"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Overview"
        android:tint="#CCCCCC"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Search Bar Container (Initially Hidden) -->
    <LinearLayout
        android:id="@+id/searchBarContainer"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/toolbar_background"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnCloseSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#CCCCCC"
            android:contentDescription="Close search" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Search handwriting..."
            android:textColor="#FFFFFF"
            android:textColorHint="#88FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tvSearchCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnPrevMatch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#CCCCCC"
            android:contentDescription="Previous match" />

        <ImageButton
            android:id="@+id/btnNextMatch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_right"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#CCCCCC"
            android:contentDescription="Next match" />

    </LinearLayout>

    <!-- Page Navigation -->
    <LinearLayout
        android:id="@+id/pageNavigationContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="16dp"
        android:background="@drawable/toolbar_background"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnPageUp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_page_up"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Previous Page"
            android:tint="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <ImageButton
            android:id="@+id/btnPageDown"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_page_down"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Next Page"
            android:tint="#CCCCCC" />

    </LinearLayout>

    <!-- ── AI Recognition Result Panel ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/recognitionPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#CC0A0A1A"
        app:layout_constraintBottom_toTopOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Spinning indicator (visible while inferring) -->
        <ProgressBar
            android:id="@+id/recognitionProgress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="#7C4DFF"
            android:visibility="gone"
            android:layout_marginEnd="10dp" />

        <!-- AI sparkle icon (visible when idle/done) -->
        <TextView
            android:id="@+id/recognitionIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textColor="#7C4DFF"
            android:textSize="16sp"
            android:layout_marginEnd="10dp" />

        <!-- Hint / recognized text -->
        <TextView
            android:id="@+id/recognitionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Draw something to recognize…"
            android:textColor="#88FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Bottom Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/toolbar_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Color swatch / picker trigger -->
        <View
            android:id="@+id/colorSwatch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/color_swatch_bg"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- Brush Size -->
        <ImageButton
            android:id="@+id/btnBrushSize"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_brush"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Brush size"
            android:tint="#CCCCCC"
            android:layout_marginStart="4dp" />


        <!-- Background -->
        <ImageButton
            android:id="@+id/btnBackground"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_background"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Page Background"
            android:tint="#CCCCCC"
            android:layout_marginStart="8dp" />

        <!-- Insert Image -->

        <ImageButton
            android:id="@+id/btnAddImage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_image"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Insert Image"
            android:tint="#CCCCCC"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/btnAddPdf"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_pdf"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Insert PDF Snippet"
            android:tint="#CCCCCC"
            android:layout_marginStart="8dp" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Undo -->
        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_undo"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Undo"
            android:tint="#CCCCCC"
            android:alpha="0.4"
            android:layout_marginEnd="8dp" />

        <!-- Redo -->
        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_redo"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Redo"
            android:tint="#CCCCCC"
            android:alpha="0.4"
            android:layout_marginEnd="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#33FFFFFF"
            android:layout_marginEnd="8dp" />

        <!-- Clear -->
        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_delete"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Clear canvas"
            android:tint="#FF6B6B" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
