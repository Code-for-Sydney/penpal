<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦ Gemma On-Device AI"
        android:textColor="#7C4DFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/dlSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Downloading the Gemma 3n model so recognition works entirely on your device."
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Progress area (shown while downloading) -->
    <LinearLayout
        android:id="@+id/dlProgressArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/dlProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#7C4DFF"
            android:progressBackgroundTint="#33FFFFFF"
            android:max="100"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dlProgressLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Starting…"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/dlProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#7C4DFF"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📶 Using Wi-Fi (recommended for large download)"
            android:textColor="#88FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>

    <!-- "Start download" state (shown before download begins) -->
    <LinearLayout
        android:id="@+id/dlReadyArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Model"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemma 3n E2B (int4)"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Size"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~1.5 GB"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Source"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HuggingFace (free)"
                android:textColor="#64FFDA"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- HuggingFace token input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HuggingFace Access Token"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etHfToken"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="hf_xxxxxxxxxxxxxxxxxxxxxxxx"
            android:textColor="#FFFFFF"
            android:textColorHint="#55FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/btn_outline"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="textPassword"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btnAcceptLicense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="① Accept License ↗"
                android:textColor="#7C4DFF"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/btnGetToken"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="② Get Read Token ↗"
                android:textColor="#7C4DFF"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- Download button -->
        <Button
            android:id="@+id/btnStartDownload"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⬇  Download Model"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_download"
            android:layout_marginBottom="10dp" />


        <!-- Skip / manual path -->
        <Button
            android:id="@+id/btnSkipDownload"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="I already have the file"
            android:textColor="#888888"
            android:textSize="13sp"
            android:background="@drawable/btn_outline" />

    </LinearLayout>

    <!-- Error message -->
    <TextView
        android:id="@+id/dlErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF6B6B"
        android:textSize="12sp"
        android:visibility="gone"
        android:layout_marginTop="8dp" />

</LinearLayout>
