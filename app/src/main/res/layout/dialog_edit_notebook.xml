<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <EditText
        android:id="@+id/etNotebookName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Notebook Name"
        android:textColor="#FFFFFF"
        android:textColorHint="#88FFFFFF"
        android:backgroundTint="#FF4081"
        android:inputType="textCapSentences"
        android:maxLength="30" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Choose Color"
        android:textColor="#88FFFFFF"
        android:textSize="14sp" />

    <GridLayout
        android:id="@+id/colorGrid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:columnCount="5" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Notebook Type"
        android:textColor="#88FFFFFF"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/rgNotebookType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbNotebook"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notebook"
            android:textColor="#FFFFFF"
            android:buttonTint="#FF4081" />

        <RadioButton
            android:id="@+id/rbWhiteboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Whiteboard"
            android:textColor="#FFFFFF"
            android:buttonTint="#FF4081" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Default Page Background"
        android:textColor="#88FFFFFF"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/rgDefaultBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbRuled"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ruled"
            android:textColor="#FFFFFF"
            android:buttonTint="#FF4081" />

        <RadioButton
            android:id="@+id/rbGraph"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Graph"
            android:textColor="#FFFFFF"
            android:buttonTint="#FF4081" />

        <RadioButton
            android:id="@+id/rbNone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="None"
            android:textColor="#FFFFFF"
            android:buttonTint="#FF4081" />
    </RadioGroup>


    <Button
        android:id="@+id/btnDeleteNotebook"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Delete Notebook"
        android:textColor="#FF4081"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

</LinearLayout>
