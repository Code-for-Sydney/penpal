<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Custom Color"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="20dp" />

    <!-- Preview -->
    <View
        android:id="@+id/hsvPreview"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <!-- Hue -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Hue" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
    <SeekBar android:id="@+id/sliderHue" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:progressTint="#FF4081"
        android:thumbTint="#FFFFFF" android:layout_marginBottom="12dp"/>

    <!-- Saturation -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Saturation" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
    <SeekBar android:id="@+id/sliderSaturation" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:progressTint="#FF4081"
        android:thumbTint="#FFFFFF" android:layout_marginBottom="12dp"/>

    <!-- Value/Brightness -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Brightness" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
    <SeekBar android:id="@+id/sliderValue" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:progressTint="#FF4081"
        android:thumbTint="#FFFFFF" android:layout_marginBottom="12dp"/>

    <!-- Opacity -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Opacity" android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="4dp"/>
    <SeekBar android:id="@+id/sliderOpacity" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:progressTint="#FF4081"
        android:thumbTint="#FFFFFF" />

</LinearLayout>
